# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/smartdrive

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# Termii (SMS OTP for Nigeria)
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=SmartDrive

# Resend (Email notifications - optional)
RESEND_API_KEY=re_your_api_key_here
# Use onboarding@resend.dev for testing (no domain verification needed)
# Change to your own domain after verifying it in Resend dashboard
RESEND_FROM_EMAIL=onboarding@resend.dev

# Server
PORT=3001
NODE_ENV=development

# OTP
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
